# Streamlit Cloud "Secrets" 설정에 그대로 붙여넣는 템플릿.
# 로컬에서 쓰려면 이 파일을 .streamlit/secrets.toml로 복사(실제 파일은 .gitignore 대상,
# 커밋되지 않음). GDrive 공유 링크(https://drive.google.com/file/d/<파일ID>/view)에서
# <파일ID> 부분만 그대로 넣으면 된다 — app/main.py가 앱 콜드스타트 시 이 값으로
# 데이터 번들을 자동으로 내려받는다(app/utils/data_bootstrap.py 참고).

REC_SYSTEM_DATA_FILE_ID = "여기에_GDrive_파일_ID"
